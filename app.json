{
  "expo": {
    "name": "LumiNUsMobile_App",
    "slug": "LumiNUsMobile_App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LumiNUs_Load.jpg",
    "userInterfaceStyle": "light",
    "backgroundColor": "#31429B",
    "splash": {
      "image": "./assets/images/nulogo.png",
      "resizeMode": "cover",
      "backgroundColor": "#31429B"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/digital-yearbook-icon-in-blue.png",
        "backgroundColor": "#31429B"
      },
      "package": "com.sakalatadik_2.LumiNUsMobile_App"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b0ff116b-bf3b-463f-bcbb-0e23eefc766a"
      }
    },
    "owner": "sakalatadik_2"
  }
}
