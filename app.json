{
  "expo": {
    "name": "LumiNUsMobile_App",
    "slug": "LumiNUsMobile_App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LumiNUs_Load.jpg",
    "userInterfaceStyle": "light",
    "backgroundColor": "#31429B",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/LumiNUs_Load.jpg",
      "resizeMode": "cover",
      "backgroundColor": "#31429B"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LumiNUs_Load.jpg",
        "backgroundColor": "#31429B"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
